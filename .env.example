# ─── Feature flags ───────────────────────────────────────────────
# Enable the YouTube/social/Spotify downloaders and AI background remover.
# These require the self-hosted Python worker. Leave UNSET on Vercel —
# the image/PDF/utility tools work there with no worker.
NEXT_PUBLIC_ENABLE_DOWNLOADS=1

# The worker-side bg-remove tool loads an ONNX model into memory (~200-400MB).
# Set to 0 on low-RAM self-host boxes (e.g. a 1GB free-tier VPS) to hide it —
# the browser-only bg-remove-client tool still works everywhere.
NEXT_PUBLIC_ENABLE_HEAVY_WORKER_TOOLS=1

# ─── Web app (apps/web/.env.local) ───────────────────────────────
NEXT_PUBLIC_APP_NAME=OmniKit
WORKER_API_URL=http://localhost:8000
STORAGE_PATH=./data/storage
# Self-hosting can go large; on Vercel keep this ~4 (serverless body limit).
MAX_FILE_SIZE_MB=100

# ─── Worker (services/worker/.env) ───────────────────────────────
STORAGE_DIR=../../data/storage
MAX_CONCURRENT_JOBS=2
JOB_TTL_HOURS=24

# Set to true to skip Redis and use a local file queue instead (no Redis needed).
USE_FILE_QUEUE=true

# Redis (only needed if USE_FILE_QUEUE=false)
REDIS_URL=redis://127.0.0.1:6379/0

# Optional: authenticate for login-gated downloads (Instagram, age-restricted X, etc.)
# Use one of the two options below:
# COOKIES_FILE=C:\path\to\cookies.txt        ← Netscape cookies.txt export (recommended)
# COOKIES_FROM_BROWSER=firefox               ← read directly from browser (firefox works best)
